    "@builder.io/qwik-city": "^1.12.0",
    "@types/node": "^20.14.0",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  },
  "pnpm": {
    "overrides": {
      "undici": "^6.21.2"
    }
  }
}
